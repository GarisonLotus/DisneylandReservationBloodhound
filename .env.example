# Disney account credentials
DISNEY_EMAIL=your_email@example.com
DISNEY_PASSWORD=your_password

# Target reservation details
TARGET_DATE=2026-04-15          # YYYY-MM-DD format
TARGET_PARK=disneyland           # disneyland | california_adventure | either
PARTY_MEMBERS=Mickey Mouse,Minnie Mouse  # Comma-separated names to select on the party page

# Operating mode
MODE=monitor                     # monitor (notify only) | book (auto-book)
POLL_INTERVAL_SECONDS=60         # Seconds between availability checks

# Notifications
DISCORD_WEBHOOK_URL=             # Discord webhook URL (leave blank to disable)
ENABLE_MACOS_NOTIFICATIONS=true  # macOS native notifications via osascript
ENABLE_DISCORD_NOTIFICATIONS=false

# Browser settings
HEADLESS=true                    # Run browser in headless mode
BROWSER_DATA_DIR=browser_data    # Persistent browser profile directory

# Auth settings
TOKEN_REFRESH_MINUTES=12         # Re-capture auth token every N minutes

# Reliability
MAX_RETRIES=3                    # Max retries per operation
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# Debugging
DEBUG_IMAGES=false               # Save screenshots to screenshots/ directory
